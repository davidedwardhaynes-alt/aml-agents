.venv/
.env
__pycache__/
*.pyc
.DS_Store

# Streamlit local state — but DO commit config.toml (theme) so hosted deploys
# pick it up. Only exclude secrets.toml.
.streamlit/secrets.toml

# User credentials — never commit (demo-grade local file with bcrypt hashes)
# On Streamlit Cloud / hosted deploys, credentials come from st.secrets instead.
auth/credentials.yaml

# User-uploaded profile photos
data/avatars/

# User obligations register — local-only persistence
data/obligations.yaml

# Consortium log — local-only persistence (will be remote backend in production)
data/consortium.yaml

# LLM-generated news articles — TRACKED IN GIT so hosted deploys ship with
# current news. Cron job re-generates and commits.
# data/generated_articles.yaml  ← intentionally NOT ignored

# Press release scrape cache (4-hour TTL; refreshed on cron) — never commit
data/press_release_cache.yaml

# Deploy paste-block — contains the live ANTHROPIC_API_KEY, cookie secret, and
# bcrypt hash. Stays local-only; the user pastes the contents into the
# Streamlit Cloud Secrets UI directly.
DEPLOY_PASTE.txt
